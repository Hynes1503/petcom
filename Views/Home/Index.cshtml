@section Scripts {
    <script>
        let currentUserId = @(currentUserId ?? 0);
        let activeReplyCommentId = null;

        // ==================== LIGHTBOX ====================
        var _imgs = [], _idx = 0;
        document.addEventListener('click', function(e) {
            var trigger = e.target.closest('.lb-trigger');
            if (!trigger) return;
            e.stopPropagation();
            var images = JSON.parse(trigger.getAttribute('data-images'));
            var idx = parseInt(trigger.getAttribute('data-index')) || 0;
            openLightbox(images, idx);
        });
        function openLightbox(images, startIdx) { _imgs = images; _idx = startIdx; document.getElementById('lightbox').classList.add('open'); document.body.style.overflow = 'hidden'; renderLightbox(); }
        function closeLightbox() { document.getElementById('lightbox').classList.remove('open'); document.body.style.overflow = ''; }
        function lbNav(dir) { _idx = (_idx + dir + _imgs.length) % _imgs.length; renderLightbox(); }
        function renderLightbox() {
            var img = document.getElementById('lbImg'); img.style.opacity = '0'; img.src = _imgs[_idx];
            img.onload = function() { img.style.opacity = '1'; };
            document.getElementById('lbCaption').textContent = _imgs.length > 1 ? 'Ảnh ' + (_idx + 1) + ' / ' + _imgs.length : '';
            var strip = document.getElementById('lbStrip'); strip.innerHTML = '';
            if (_imgs.length > 1) {
                for (var i = 0; i < _imgs.length; i++) {
                    (function(idx) {
                        var t = document.createElement('img'); t.src = _imgs[idx]; t.alt = 'Ảnh ' + (idx + 1);
                        t.className = 'lb-thumb' + (idx === _idx ? ' active' : '');
                        t.addEventListener('click', function(e) { e.stopPropagation(); _idx = idx; renderLightbox(); });
                        strip.appendChild(t);
                    })(i);
                }
            }
            var single = _imgs.length <= 1;
            document.getElementById('lbPrev').style.display = single ? 'none' : 'flex';
            document.getElementById('lbNext').style.display = single ? 'none' : 'flex';
        }
        document.getElementById('lightbox').addEventListener('click', function(e) { if (e.target === this) closeLightbox(); });
        document.addEventListener('keydown', function(e) {
            if (!document.getElementById('lightbox').classList.contains('open')) return;
            if (e.key === 'Escape') closeLightbox();
            if (e.key === 'ArrowLeft') lbNav(-1);
            if (e.key === 'ArrowRight') lbNav(1);
        });

        // ==================== LOAD COMMENTS FOR POST ====================
        function loadCommentsForPost(postId) {
            fetch('/Comment/List?postId=' + postId)
                .then(res => res.json())
                .then(comments => {
                    const container = document.getElementById('comment-list-' + postId);
                    if (comments.length === 0) {
                        container.innerHTML = '<p style="font-size:13px;color:var(--text-muted);text-align:center;padding:8px 0 4px;">Chưa có bình luận nào.</p>';
                        return;
                    }
                    container.innerHTML = '';
                    comments.forEach(comment => {
                        container.appendChild(buildCommentInline(comment, postId));
                    });
                });
        }

        // Build comment HTML for inline
        function buildCommentInline(comment, postId) {
            const div = document.createElement('div');
            div.className = 'comment-item';
            div.setAttribute('data-comment-id', comment.id);

            const avatarHtml = comment.userAvatar
                ? `<img src="${comment.userAvatar}" alt="${escapeHtml(comment.username)}" style="width:100%;height:100%;border-radius:50%;object-fit:cover;" />`
                : `<span>${escapeHtml(comment.username)[0].toUpperCase()}</span>`;
            const reportBtn = (currentUserId && currentUserId !== (comment.userId || 0))
                ? `<button class="rp-cmt-btn" onclick="openCommentReport(${comment.id})" title="Báo cáo bình luận">🚩 Báo cáo</button>`
                : '';

            div.innerHTML = `
                <div class="comment-avatar">
                    ${avatarHtml}
                </div>
                <div class="comment-bubble">
                    <div class="comment-username">${escapeHtml(comment.username)}</div>
                    <div class="comment-text">${escapeHtml(comment.content)}</div>
                    <div class="comment-time">${comment.createdAt}</div>
                    <div class="comment-actions">
                        <button class="reply-btn" onclick="showReplyFormInline(${comment.id}, ${postId})">
                            <i class="fa-regular fa-reply"></i> Phản hồi
                        </button>
                        <button class="toggle-replies-btn" id="toggle-replies-${comment.id}" onclick="toggleRepliesInline(${comment.id})">
                            <i class="fa-regular fa-comment-dots"></i> Xem phản hồi (${comment.replyCount || 0})
                        </button>
                        ${reportBtn}
                    </div>
                    <div class="reply-form" id="reply-form-${comment.id}" style="display: none;">
                        <textarea class="reply-input" id="reply-input-${comment.id}" rows="2" placeholder="Viết phản hồi..."></textarea>
                        <div class="reply-form-actions">
                            <button class="reply-cancel" onclick="showReplyFormInline(${comment.id}, ${postId})">Hủy</button>
                            <button class="reply-submit" onclick="submitReplyInline(${comment.id}, ${postId})">Gửi phản hồi</button>
                        </div>
                    </div>
                    <div class="replies-container" id="replies-${comment.id}" style="display: none;"></div>
                </div>
            `;
            return div;
        }

        // Submit new comment inline
        function submitNewCommentInline(postId) {
            const input = document.getElementById('comment-input-' + postId);
            const content = input.value.trim();
            if (!content) {
                alert('Vui lòng nhập nội dung bình luận');
                return;
            }

            fetch('/Comment/Add', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: 'postId=' + postId + '&content=' + encodeURIComponent(content)
            })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    input.value = '';
                    loadCommentsForPost(postId);
                    // Update comment count
                    const btn = document.getElementById('cmt-btn-' + postId);
                    const span = btn ? btn.querySelector('.cmt-count') : null;
                    if (span) span.textContent = parseInt(span.textContent || '0') + 1;
                } else {
                    alert('Không thể gửi bình luận. Vui lòng thử lại.');
                }
            });
        }

        // Show/hide reply form inline
        function showReplyFormInline(commentId, postId) {
            if (activeReplyCommentId === commentId) {
                const replyForm = document.getElementById(`reply-form-${commentId}`);
                if (replyForm) replyForm.style.display = 'none';
                activeReplyCommentId = null;
            } else {
                if (activeReplyCommentId) {
                    const oldForm = document.getElementById(`reply-form-${activeReplyCommentId}`);
                    if (oldForm) oldForm.style.display = 'none';
                }
                const replyForm = document.getElementById(`reply-form-${commentId}`);
                if (replyForm) {
                    replyForm.style.display = 'block';
                    replyForm.querySelector('.reply-input')?.focus();
                }
                activeReplyCommentId = commentId;
            }
        }

        // Submit reply inline
        async function submitReplyInline(commentId, postId) {
            const input = document.getElementById(`reply-input-${commentId}`);
            const content = input.value.trim();

            if (!content) {
                alert('Vui lòng nhập nội dung phản hồi');
                return;
            }

            const submitBtn = document.querySelector(`#reply-form-${commentId} .reply-submit`);
            const originalText = submitBtn.textContent;
            submitBtn.disabled = true;
            submitBtn.textContent = 'Đang gửi...';

            try {
                const response = await fetch('/CommentReply/Create', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded',
                        'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || ''
                    },
                    body: `commentId=${commentId}&content=${encodeURIComponent(content)}`
                });

                const data = await response.json();

                if (data.success) {
                    input.value = '';
                    await loadRepliesInline(commentId);

                    const replyCountSpan = document.querySelector(`#toggle-replies-${commentId}`);
                    if (replyCountSpan) {
                        const match = replyCountSpan.textContent.match(/\((\d+)\)/);
                        const currentCount = match ? parseInt(match[1]) : 0;
                        replyCountSpan.innerHTML = `<i class="fa-regular fa-comment-dots"></i> Xem phản hồi (${currentCount + 1})`;
                    }

                    document.getElementById(`reply-form-${commentId}`).style.display = 'none';
                    activeReplyCommentId = null;
                } else {
                    alert(data.message || 'Không thể gửi phản hồi');
                }
            } catch (error) {
                alert('Có lỗi xảy ra, vui lòng thử lại');
            } finally {
                submitBtn.disabled = false;
                submitBtn.textContent = originalText;
            }
        }

        // Load replies inline
        async function loadRepliesInline(commentId) {
            const container = document.getElementById(`replies-${commentId}`);
            if (!container) return;

            try {
                const response = await fetch(`/CommentReply/List?commentId=${commentId}`);
                const replies = await response.json();

                if (replies.length === 0) {
                    container.innerHTML = '<div class="no-replies">Chưa có phản hồi nào</div>';
                    return;
                }

                container.innerHTML = replies.map(reply => `
                    <div class="reply-item" id="reply-${reply.id}">
                        <div class="reply-avatar">
                            ${reply.userAvatar ? `<img src="${reply.userAvatar}" alt="${escapeHtml(reply.username)}" />` : `<span>${escapeHtml(reply.username)[0].toUpperCase()}</span>`}
                        </div>
                        <div class="reply-content">
                            <div class="reply-header">
                                <span class="reply-username">${escapeHtml(reply.username)}</span>
                                <span class="reply-time">${reply.createdAt}</span>
                                ${reply.isEdited ? '<span class="reply-edited">(đã sửa)</span>' : ''}
                            </div>
                            <div class="reply-text">${escapeHtml(reply.content)}</div>
                            ${currentUserId === reply.userId ? `
                                <div class="reply-actions">
                                    <button class="reply-action-btn edit-reply" onclick="editReplyInline(${reply.id}, '${escapeHtml(reply.content).replace(/'/g, "\\'")}')">
                                        <i class="fa-regular fa-pen-to-square"></i> Sửa
                                    </button>
                                    <button class="reply-action-btn delete-reply" onclick="deleteReplyInline(${reply.id})">
                                        <i class="fa-regular fa-trash-can"></i> Xóa
                                    </button>
                                </div>
                            ` : ''}
                        </div>
                    </div>
                `).join('');

            } catch (error) {
                console.error('Error loading replies:', error);
            }
        }

        // Toggle replies visibility inline
        function toggleRepliesInline(commentId) {
            const repliesContainer = document.getElementById(`replies-${commentId}`);
            const toggleBtn = document.querySelector(`#toggle-replies-${commentId}`);

            if (repliesContainer.style.display === 'none' || !repliesContainer.style.display) {
                repliesContainer.style.display = 'block';
                toggleBtn.innerHTML = '<i class="fa-regular fa-comment-dots"></i> Ẩn phản hồi';
                if (repliesContainer.innerHTML === '') {
                    loadRepliesInline(commentId);
                }
            } else {
                repliesContainer.style.display = 'none';
                const replyCount = repliesContainer.querySelectorAll('.reply-item').length;
                toggleBtn.innerHTML = `<i class="fa-regular fa-comment-dots"></i> Xem phản hồi (${replyCount})`;
            }
        }

        // Edit reply inline
        async function editReplyInline(replyId, oldContent) {
            const newContent = prompt('Sửa phản hồi của bạn:', oldContent);
            if (!newContent || newContent === oldContent) return;

            const response = await fetch('/CommentReply/Edit', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                    'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || ''
                },
                body: `replyId=${replyId}&content=${encodeURIComponent(newContent)}`
            });

            const data = await response.json();

            if (data.success) {
                const replyDiv = document.getElementById(`reply-${replyId}`);
                if (replyDiv) {
                    const commentId = replyDiv.closest('.comment-item')?.getAttribute('data-comment-id');
                    if (commentId) await loadRepliesInline(parseInt(commentId));
                }
            } else {
                alert(data.message || 'Không thể sửa phản hồi');
            }
        }

        // Delete reply inline
        async function deleteReplyInline(replyId) {
            if (!confirm('Bạn có chắc chắn muốn xóa phản hồi này?')) return;

            const response = await fetch('/CommentReply/Delete', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                    'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || ''
                },
                body: `replyId=${replyId}`
            });

            const data = await response.json();

            if (data.success) {
                const replyDiv = document.getElementById(`reply-${replyId}`);
                if (replyDiv) {
                    const commentId = replyDiv.closest('.comment-item')?.getAttribute('data-comment-id');
                    if (commentId) {
                        await loadRepliesInline(parseInt(commentId));
                        const toggleBtn = document.querySelector(`#toggle-replies-${commentId}`);
                        if (toggleBtn) {
                            const match = toggleBtn.textContent.match(/\((\d+)\)/);
                            const currentCount = match ? parseInt(match[1]) : 0;
                            toggleBtn.innerHTML = `<i class="fa-regular fa-comment-dots"></i> Xem phản hồi (${Math.max(0, currentCount - 1)})`;
                        }
                    }
                }
            } else {
                alert(data.message || 'Không thể xóa phản hồi');
            }
        }

        // ==================== TOGGLE COMMENTS ====================
        function toggleComments(btn, postId) {
            var section = document.getElementById('comments-' + postId);
            if (!section) return;
            var opening = !section.classList.contains('open');
            section.classList.toggle('open');
            btn.classList.toggle('cmt-open');
            if (opening && document.getElementById('comment-list-' + postId).innerHTML === '') {
                loadCommentsForPost(postId);
            }
        }

        // ==================== BOOKMARK ====================
        function toggleBookmark(btn, postId) {
            fetch('/Bookmark/Toggle', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                    'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || ''
                },
                body: 'postId=' + postId
            })
            .then(res => res.json())
            .then(data => {
                if (!data.success) { openModal('login'); return; }
                if (data.saved) {
                    btn.classList.add('saved');
                    btn.textContent = '🔖 Đã lưu';
                } else {
                    btn.classList.remove('saved');
                    btn.textContent = '🔖 Lưu bài';
                }
            });
        }

        // ==================== ESCAPE HTML ====================
        function escapeHtml(str) {
            if (!str) return '';
            return String(str)
                .replace(/&/g, '&amp;')
                .replace(/</g, '&lt;')
                .replace(/>/g, '&gt;')
                .replace(/"/g, '&quot;')
                .replace(/'/g, '&#39;');
        }

        // ==================== AUTH MODAL ====================
        function openModal(tab) {
            document.getElementById('modal-overlay').classList.add('active');
            switchTab(tab);
        }
        function closeModal() {
            document.getElementById('modal-overlay').classList.remove('active');
        }
        function switchTab(tab) {
            document.querySelectorAll('.tab-content').forEach(function(t) { t.classList.remove('active'); });
            document.querySelectorAll('.tab-btn').forEach(function(t) { t.classList.remove('active'); });
            document.getElementById('tab-' + tab).classList.add('active');
            document.getElementById('tab-' + tab + '-btn').classList.add('active');
        }
        document.getElementById('modal-overlay').addEventListener('click', function(e) {
            if (e.target === this) closeModal();
        });

        // ==================== REPORT FUNCTIONS ====================
        function openPostReport(postId) {
            if (typeof window.openPostReport === 'function') {
                window.openPostReport(postId);
            } else {
                console.error('openPostReport function not found');
                alert('Chức năng báo cáo tạm thời không khả dụng');
            }
        }

        function openCommentReport(commentId) {
            if (typeof window.openCommentReport === 'function') {
                window.openCommentReport(commentId);
            } else {
                console.error('openCommentReport function not found');
                alert('Chức năng báo cáo tạm thời không khả dụng');
            }
        }

        @if (TempData["LoginError"] != null)
        {
            <text>window.addEventListener('DOMContentLoaded', function() { openModal('login'); });</text>
        }
        else if (TempData["RegisterError"] != null)
        {
            <text>window.addEventListener('DOMContentLoaded', function() { openModal('register'); });</text>
        }
    </script>
}