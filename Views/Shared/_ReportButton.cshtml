@* Views/Shared/_ReportButton.cshtml
   Dùng trong bất kỳ view nào hiển thị bài đăng:
   @await Html.PartialAsync("_ReportButton", post.Id)
*@
@model int

<button class="report-trigger-btn" onclick="openReportModal(@Model)" title="Báo cáo bài đăng">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"/>
        <line x1="4" y1="22" x2="4" y2="15"/>
    </svg>
    Báo cáo
</button>
