@model AdminDashboardViewModel
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Dashboard";
    ViewData["ActiveMenu"] = "dashboard";
}

<div class="admin-page-header">
    <h1 class="page-title">Dashboard</h1>
    <span class="page-subtitle">Tổng quan hệ thống PetComm</span>
</div>

<!-- Stats Cards -->
<div class="stats-grid">
    <div class="stat-card stat-users">
        <div class="stat-icon">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        </div>
        <div class="stat-info">
            <div class="stat-value">@Model.TotalUsers</div>
            <div class="stat-label">Tổng người dùng</div>
            <div class="stat-sub">@Model.ActiveUsers đang hoạt động</div>
        </div>
    </div>

    <div class="stat-card stat-posts">
        <div class="stat-icon">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14,2 14,8 20,8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10,9 9,9 8,9"/></svg>
        </div>
        <div class="stat-info">
            <div class="stat-value">@Model.TotalPosts</div>
            <div class="stat-label">Tổng bài đăng</div>
            <div class="stat-sub">@Model.ActivePosts đang hiển thị</div>
        </div>
    </div>

    <div class="stat-card stat-inactive-users">
        <div class="stat-icon">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="4.93" y1="4.93" x2="19.07" y2="19.07"/></svg>
        </div>
        <div class="stat-info">
            <div class="stat-value">@(Model.TotalUsers - Model.ActiveUsers)</div>
            <div class="stat-label">Tài khoản bị khoá</div>
            <div class="stat-sub">Cần xem xét</div>
        </div>
    </div>

    <div class="stat-card stat-hidden-posts">
        <div class="stat-icon">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/></svg>
        </div>
        <div class="stat-info">
            <div class="stat-value">@(Model.TotalPosts - Model.ActivePosts)</div>
            <div class="stat-label">Bài đăng ẩn</div>
            <div class="stat-sub">Không hiển thị</div>
        </div>
    </div>
</div>

<!-- Recent Data Tables -->
<div class="dashboard-tables">
    <div class="table-card">
        <div class="table-card-header">
            <h3>Người dùng mới nhất</h3>
            <a href="/admin/users" class="view-all-link">Xem tất cả →</a>
        </div>
        <table class="admin-table">
            <thead>
                <tr>
                    <th>Người dùng</th>
                    <th>Email</th>
                    <th>Vai trò</th>
                    <th>Trạng thái</th>
                    <th>Ngày tạo</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model.RecentUsers)
                {
                    <tr>
                        <td>
                            <div class="user-cell">
                                @if (!string.IsNullOrEmpty(user.AvatarPath))
                                {
                                    <img src="@user.AvatarPath" class="mini-avatar" alt="@user.Username" />
                                }
                                else
                                {
                                    <div class="mini-avatar-placeholder">@(user.Username?.Substring(0, 1).ToUpper())</div>
                                }
                                <span>@user.Username</span>
                            </div>
                        </td>
                        <td class="text-muted">@user.Email</td>
                        <td><span class="role-badge role-@user.Role?.ToLower()">@user.Role</span></td>
                        <td>
                            @if (user.IsActive)
                            {
                                <span class="status-dot active"></span>
                            }
                            else
                            {
                                <span class="status-dot inactive"></span>
                            }
                        </td>
                        <td class="text-muted">@user.CreatedAt.ToString("dd/MM/yyyy")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="table-card">
        <div class="table-card-header">
            <h3>Bài đăng mới nhất</h3>
            <a href="/admin/posts" class="view-all-link">Xem tất cả →</a>
        </div>
        <table class="admin-table">
            <thead>
                <tr>
                    <th>Tiêu đề</th>
                    <th>Tác giả</th>
                    <th>Loại</th>
                    <th>Trạng thái</th>
                    <th>Ngày đăng</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var post in Model.RecentPosts)
                {
                    <tr>
                        <td>
                            <a href="/admin/posts/@post.Id" class="post-title-link">@(post.Title?.Length > 40 ? post.Title.Substring(0, 40) + "..." : post.Title)</a>
                        </td>
                        <td class="text-muted">@post.User?.Username</td>
                        <td><span class="type-badge">@post.Type</span></td>
                        <td>
                            <span class="status-badge status-@post.Status?.ToLower()">@post.Status</span>
                        </td>
                        <td class="text-muted">@post.CreatedAt.ToString("dd/MM/yyyy")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
