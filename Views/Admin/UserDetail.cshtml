@model User
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["ActiveMenu"] = "users";
    var posts = ViewBag.UserPosts as List<Post> ?? new();
}

<a href="/admin/users" class="back-link">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12,19 5,12 12,5"/></svg>
    Quay lại danh sách
</a>

<div class="admin-page-header">
    <div>
        <h1 class="page-title">@Model.Username</h1>
        <span class="page-subtitle">Chi tiết tài khoản · ID #@Model.Id</span>
    </div>
</div>

<div class="detail-grid">
    <!-- Info -->
    <div>
        <div class="info-card" style="text-align:center; margin-bottom:16px; padding:32px 24px;">
            @if (!string.IsNullOrEmpty(Model.AvatarPath))
            {
                <img src="@Model.AvatarPath" style="width:80px;height:80px;border-radius:50%;object-fit:cover;margin-bottom:14px;" />
            }
            else
            {
                <div style="width:80px;height:80px;border-radius:50%;background:var(--primary-dim);color:var(--primary);display:flex;align-items:center;justify-content:center;font-size:32px;font-weight:700;margin:0 auto 14px;">
                    @(Model.Username?.Substring(0, 1).ToUpper())
                </div>
            }
            <div style="font-size:18px;font-weight:700;">@Model.Username</div>
            @if (!string.IsNullOrEmpty(Model.FullName))
            {
                <div style="font-size:14px;color:var(--text-muted);margin-top:4px;">@Model.FullName</div>
            }
            <div style="margin-top:12px;">
                <span class="role-badge role-@Model.Role?.ToLower()">@Model.Role</span>
            </div>
        </div>

        <div class="info-card">
            <div class="section-title">Thông tin tài khoản</div>
            <div class="info-row">
                <label>Email</label>
                <span>@(Model.Email ?? "—")</span>
            </div>
            <div class="info-row">
                <label>Số điện thoại</label>
                <span>@(Model.PhoneNumber ?? "—")</span>
            </div>
            <div class="info-row">
                <label>Trạng thái</label>
                <span>
                    @if (Model.IsActive)
                    {
                        <span class="status-dot active"></span>
                        <span style="color:var(--green);margin-left:6px;">Đang hoạt động</span>
                    }
                    else
                    {
                        <span class="status-dot inactive"></span>
                        <span style="color:var(--red);margin-left:6px;">Bị khoá</span>
                    }
                </span>
            </div>
            <div class="info-row">
                <label>Ngày tạo</label>
                <span>@Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</span>
            </div>
            @if (!string.IsNullOrEmpty(Model.Bio))
            {
                <div class="info-row">
                    <label>Bio</label>
                    <span>@Model.Bio</span>
                </div>
            }
        </div>

        <div class="info-card" style="margin-top:16px;">
            <div class="section-title">Hành động</div>
            <div style="display:flex;gap:10px;flex-wrap:wrap;">
                <button class="btn-filter" onclick="toggleStatus(@Model.Id)" id="toggleBtn"
                        style="background:@(Model.IsActive ? "var(--red)" : "var(--green)")">
                    @(Model.IsActive ? "Khoá tài khoản" : "Kích hoạt")
                </button>
            </div>
            <div style="margin-top:12px;">
                <label style="font-size:12px;color:var(--text-muted);font-weight:600;text-transform:uppercase;letter-spacing:0.5px;display:block;margin-bottom:8px;">Đổi vai trò</label>
                <select id="roleSelect" style="padding:9px 12px;background:var(--surface2);border:1px solid var(--border);border-radius:8px;color:var(--text);font-size:14px;font-family:'DM Sans',sans-serif;outline:none;width:100%;">
                    <option value="Member" selected="@(Model.Role == "Member")">Member</option>
                    <option value="Admin" selected="@(Model.Role == "Admin")">Admin</option>
                    <option value="Moderator" selected="@(Model.Role == "Moderator")">Moderator</option>
                </select>
                <button class="btn-filter" onclick="changeRole(@Model.Id)" style="margin-top:8px;width:100%;">Lưu vai trò</button>
            </div>
        </div>
    </div>

    <!-- Posts -->
    <div>
        <div class="info-card">
            <div class="section-title">Bài đăng (@posts.Count)</div>
            @if (posts.Any())
            {
                <table class="admin-table" style="margin:-1px;">
                    <thead>
                        <tr>
                            <th>Tiêu đề</th>
                            <th>Loại</th>
                            <th>Trạng thái</th>
                            <th>Ngày đăng</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var post in posts)
                        {
                            <tr>
                                <td>
                                    <span class="fw-600">@(post.Title?.Length > 50 ? post.Title.Substring(0, 50) + "..." : post.Title)</span>
                                </td>
                                <td><span class="type-badge">@post.Type</span></td>
                                <td><span class="status-badge status-@post.Status?.ToLower()">@post.Status</span></td>
                                <td class="text-muted">@post.CreatedAt.ToString("dd/MM/yy")</td>
                                <td>
                                    <a href="/admin/posts/@post.Id" class="btn-icon">
                                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <div class="empty-state">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14,2 14,8 20,8"/></svg>
                    <p>Chưa có bài đăng nào</p>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
<script>
    const TOKEN = document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';

    async function toggleStatus(id) {
        const res = await fetch(`/admin/users/${id}/toggle-status`, {
            method: 'POST', headers: { 'RequestVerificationToken': TOKEN }
        });
        const data = await res.json();
        if (data.success) {
            showToast(data.message, 'success');
            setTimeout(() => location.reload(), 800);
        } else showToast(data.message, 'error');
    }

    async function changeRole(id) {
        const role = document.getElementById('roleSelect').value;
        const fd = new FormData();
        fd.append('role', role);
        const res = await fetch(`/admin/users/${id}/change-role`, {
            method: 'POST', headers: { 'RequestVerificationToken': TOKEN }, body: fd
        });
        const data = await res.json();
        showToast(data.message, data.success ? 'success' : 'error');
    }

    function showToast(msg, type) {
        const t = document.createElement('div');
        t.className = `toast toast-${type}`;
        t.textContent = msg;
        document.body.appendChild(t);
        setTimeout(() => t.classList.add('show'), 10);
        setTimeout(() => { t.classList.remove('show'); setTimeout(() => t.remove(), 300); }, 3000);
    }
</script>
}
